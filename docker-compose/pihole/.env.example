# Pro Deployment anzupassen. Sichere Werte (Passwoerter) NICHT
# ins Repo committen — siehe .gitignore.

# Image-Tag. Default "latest". Fuer reproduzierbare Deploys einen
# konkreten Tag (z. B. "2026.07.2") pinnen.
PIHOLE_IMAGE_TAG=latest

# Host-Port fuer direkten Zugriff auf die Web-UI ohne Traefik.
# Container laeuft intern auf 80. Bei Kollisionen anpassen.
PIHOLE_HOST_PORT_HTTP=8080

# Host-Port fuer direkten Zugriff auf das FTL-self-signed-Zertifikat
# (nur ohne Traefik noetig). Container laeuft intern auf 443.
PIHOLE_HOST_PORT_HTTPS=8443

# Zeitzone fuer den Container.
PIHOLE_TZ=Europe/Berlin

# Web-UI-Passwort (Pi-hole v6: FTLCONF_webserver_api_password).
# LANGE Zufallszeichenkette verwenden — NICHT committen.
# ⚠️ ZWINGEND ersetzen — siehe README.
PIHOLE_WEBPASSWORD=changeme

# Traefik-Domain fuer den DNS-Rebind-Whitelist-Eintrag. Muss exakt
# der Domain entsprechen, die auch im Compose als
# `traefik.http.routers.pihole.rule=Host(...)` hinterlegt ist, und VOR
# dem ersten Start konsistent gesetzt sein. Default pihole.example.com.
PIHOLE_TRAEFIK_DOMAIN=pihole.example.com

# Name des externen Traefik-Netzwerks. Nur im Swarm-Pfad relevant
# (docker-compose.swarm.yml). Muss vor `docker stack deploy` existieren:
# `docker network create --driver=overlay proxy`.
PROXY_NETWORK_NAME=proxy

# Auf `true` setzen, wenn Pi-hole als DHCP-Server dienen soll.
# Aktiviert implizit NET_ADMIN (siehe docker-compose.yml cap_add).
PIHOLE_ENABLE_DHCP=false

# Auf `true` setzen, wenn Pi-hole als NTP-Client dienen soll.
# Aktiviert implizit SYS_TIME (siehe docker-compose.yml cap_add).
PIHOLE_ENABLE_NTP=false
