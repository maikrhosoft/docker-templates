# Pro Deployment anzupassen. Sichere Werte (Passwoerter, Tokens) NICHT
# ins Repo committen — siehe .gitignore.

# Host-Port, unter dem Dockhand erreichbar ist. Bei Port-Kollisionen
# (z. B. mit anderen lokalen Web-UI-Diensten) anpassen.
DOCKHAND_HOST_PORT=3000

# Image-Tag. Default "latest". Fuer reproduzierbare Deploys einen
# konkreten Tag (z. B. "1.2.3") pinnen.
DOCKHAND_IMAGE_TAG=latest
