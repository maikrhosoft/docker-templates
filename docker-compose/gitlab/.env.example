# Pro Deployment anzupassen (alle nicht-sicherheitsrelevant, aber host-spezifisch).
#
# Sicherheitsrelevante Werte (Passwoerter, Tokens) sind in diesem Stack NICHT noetig:
# GitLab verwaltet Authentifizierung intern, SMTP- und sonstige Credentials werden
# bei Bedarf in GITLAB_OMNIBUS_CONFIG in docker-compose.yml gesetzt.

# FQDN, unter dem GitLab extern erreichbar ist (ueber Synology Reverse Proxy)
GITLAB_EXTERNAL_URL=https://gitlab.example.tld

# Hostname des Containers (oft identisch mit FQDN)
GITLAB_HOSTNAME=gitlab.example.tld

# Absender fuer System-Mails (Notifications, Passwort-Resets etc.)
GITLAB_EMAIL_FROM=gitlab@example.tld

# Bridge-Netz-Name (Compose legt dieses Netz automatisch an).
GITLAB_BRIDGE_NETWORK_NAME=gitlab-bridge

# Host-Ports, unter denen GitLab von aussen (Synology Reverse Proxy, SSH-Clients)
# erreichbar ist. Bei Konflikten mit lokalen Diensten anpassen.
# Typische Kollisionen auf Synology: 22 (DSM), 80/443 (andere Web-UI).
GITLAB_SSH_HOST_PORT=2222
GITLAB_HTTP_HOST_PORT=8080
GITLAB_HTTPS_HOST_PORT=8443

# Registration-Token fuer den GitLab-Runner (Autoregister).
# Quelle: GitLab Web-UI -> Admin -> CI/CD -> Runners -> "New instance runner"
# bzw. Group-/Project-Runner-Token. Token wird beim ersten Start des
# gitlab-runner-Containers verbraucht; Rotation: siehe README Abschnitt
# "GitLab Runner registrieren".
GITLAB_RUNNER_TOKEN=glrt-XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Interne URL, unter der der gitlab-runner den gitlab-Service im
# Compose-Netz "gitlab-internal" erreicht. Normalerweise nicht aendern.
# Anpassen, falls der Service-Name im Compose-Netz abweicht.
GITLAB_INTERNAL_URL=http://gitlab
